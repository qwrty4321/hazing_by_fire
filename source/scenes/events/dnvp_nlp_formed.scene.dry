on-arrival: {!

Q.dnvp_nlp_formed = 1;
Q.nlp_exist = 0;

Q.parties_graph.push('fkp');

if (Q.kvp_formed) {
    Q.workers_kvp += Q.workers_nlp;
    Q.new_middle_kvp += Q.new_middle_nlp;
    Q.old_middle_kvp += Q.old_middle_nlp;
    Q.rural_kvp += Q.rural_nlp;
    Q.catholics_kvp += Q.catholics_nlp;
    Q.unemployed_kvp += Q.unemployed_nlp;
    Q.kvp_r += Q.nlp_r;
    Q.nlp_r = 0;
    Q.kvp_r_prussia += Q.nlp_r_prussia;
    Q.nlp_r_prussia = 0;
    Q.kvp_relation = (Q.kvp_relation + Q.nlp_relation) / 2;
} else {
    Q.parties.push('kvp');
    Q.kvp_formed = 1;
    Q.dnvp_defunct = 1;
    Q.workers_kvp = Q.workers_nlp + Q.workers_dnvp;
    Q.new_middle_kvp = Q.new_middle_nlp + Q.new_middle_dnvp;
    Q.old_middle_kvp = Q.old_middle_nlp + Q.old_middle_dnvp;
    Q.rural_kvp = Q.rural_nlp + Q.rural_dnvp;
    Q.catholics_kvp = Q.catholics_nlp + Q.catholics_dnvp;
    Q.unemployed_kvp = Q.unemployed_nlp + Q.unemployed_dnvp;
    Q.kvp_r = Q.nlp_r + Q.dnvp_r;
    Q.nlp_r = 0;
    Q.dnvp_r = 0;
    Q.kvp_r_prussia = Q.nlp_r_prussia + Q.dnvp_r_prussia;
    Q.nlp_r_prussia = 0;
    Q.dnvp_r_prussia = 0;
    Q.kvp_relation = (Q.dnvp_relation + Q.nlp_relation) / 2;
    Q.dnvp_votes = 0;
    Q.dnvp_normalized = 0;
    Q.parties = Q.parties.filter(party => party !== 'dnvp');
}

Q.nlp_votes = 0;
Q.nlp_normalized = 0;
Q.liberal_parliament = 0;
Q.parties = Q.parties.filter(party => party !== 'nlp');

if (Q.winner_fkp = "Glatzel") {
    if (Q.dnvp_ideology == "Moderate") {
        Q.old_middle_dnf += Q.old_middle_kvp * 0.2;
        Q.old_middle_kvp = Q.old_middle_kvp * 0.8;
    } else {
        Q.old_middle_dnvp += Q.old_middle_kvp * 0.2;
        Q.old_middle_kvp = Q.old_middle_kvp * 0.8;
    }
    Q.fkp_radicalism = 0;
    Q.new_middle_fvp += Q.new_middle_kvp * 0.1;
    Q.new_middle_kvp = Q.new_middle_kvp * 0.9;
}

if (Q.winner_fkp = "Raumer") {
    if (Q.dnvp_ideology == "Moderate") {
        Q.rural_dnf += Q.rural_kvp * 0.2;
        Q.rural_kvp = Q.rural_kvp * 0.8;
        Q.new_middle_kvp += Q.new_middle_dnf * 0.4;
        Q.new_middle_dnf = Q.new_middle_dnf * 0.6;
    } else {
        Q.rural_dnvp += Q.rural_kvp * 0.2;
        Q.rural_kvp = Q.rural_kvp * 0.8;
        Q.new_middle_kvp += Q.new_middle_dnvp * 0.4;
        Q.new_middle_dnvp = Q.new_middle_dnvp * 0.6;
    }
    Q.fkp_radicalism = 1;
    Q.new_middle_fvp += Q.new_middle_kvp * 0.2;
    Q.new_middle_kvp = Q.new_middle_kvp * 0.8;
    Q.workers_fvp += Q.workers_kvp * 0.5;
    Q.workers_kvp = Q.workers_kvp * 0.5;
}

if (Q.winner_fkp = "Treviranus") {
    if (Q.dnvp_ideology == "Moderate") {
        Q.rural_dnf += Q.rural_kvp * 0.1;
        Q.rural_kvp = Q.rural_kvp * 0.9;
        Q.new_middle_kvp += Q.new_middle_dnf * 0.3;
        Q.new_middle_dnf = Q.new_middle_dnf * 0.7;
    } else {
        Q.rural_dnvp += Q.rural_kvp * 0.1;
        Q.rural_kvp = Q.rural_kvp * 0.9;
        Q.new_middle_kvp += Q.new_middle_dnvp * 0.3;
        Q.new_middle_dnvp = Q.new_middle_dnvp * 0.7;
    }
    Q.fkp_radicalism = 1;
    Q.new_middle_fvp += Q.new_middle_kvp * 0.2;
    Q.new_middle_kvp = Q.new_middle_kvp * 0.8;
    Q.workers_fvp += Q.workers_kvp * 0.4;
    Q.workers_kvp = Q.workers_kvp * 0.6;
}

if (Q.winner_fkp = "Hergt") {
    if (Q.dnvp_ideology == "Moderate") {
        Q.rural_kvp += Q.rural_dnf * 0.2;
        Q.rural_dnf = Q.rural_dnf * 0.8;
        Q.old_middle_kvp += Q.old_middle_dnf * 0.3;
        Q.old_middle_dnf = Q.old_middle_dnf * 0.7;
    } else {
        Q.rural_kvp += Q.rural_dnvp * 0.2;
        Q.rural_dnvp = Q.rural_dnvp * 0.8;
        Q.old_middle_kvp += Q.old_middle_dnvp * 0.3;
        Q.old_middle_dnvp = Q.old_middle_dnvp * 0.7;
    }
    Q.fkp_radicalism = 2;
    Q.new_middle_fvp += Q.new_middle_kvp * 0.3;
    Q.new_middle_kvp = Q.new_middle_kvp * 0.7;
}

if (Q.winner_fkp = "Westarp") {
    if (Q.dnvp_ideology == "Moderate") {
        Q.rural_kvp += Q.rural_dnf * 0.4;
        Q.rural_dnf = Q.rural_dnf * 0.6;
        Q.old_middle_kvp += Q.old_middle_dnf * 0.3;
        Q.old_middle_dnf = Q.old_middle_dnf * 0.7;
    } else {
        Q.rural_kvp += Q.rural_dnvp * 0.4;
        Q.rural_dnvp = Q.rural_dnvp * 0.6;
        Q.old_middle_kvp += Q.old_middle_dnvp * 0.3;
        Q.old_middle_dnvp = Q.old_middle_dnvp * 0.7;
    }
    Q.fkp_radicalism = 2;
    Q.new_middle_fvp += Q.new_middle_kvp * 0.4;
    Q.new_middle_kvp = Q.new_middle_kvp * 0.6;
}

if (Q.lvp_formed) {
    Q.weimar_coalition = parseFloat((Q.spd_r + Q.lvp_r + Q.z_r - Q.bvp_r).toFixed(1));
} else {
    Q.weimar_coalition = parseFloat((Q.spd_r + Q.fvp_r + Q.z_r - Q.bvp_r).toFixed(1));
}

if (Q.lvp_formed) {
    Q.social_liberal_coalition = parseFloat((Q.spd_r + Q.lvp_r).toFixed(1));
} else {
    Q.social_liberal_coalition = parseFloat((Q.spd_r + Q.fvp_r).toFixed(1));
}

Q.social_catholic_coalition = parseFloat((Q.spd_r + Q.z_r - Q.bvp_r).toFixed(1));

Q.grand_coalition = parseFloat((Q.spd_r + Q.kvp_r).toFixed(1));

Q.bourgeois_coalition = parseFloat((Q.fvp_r + Q.z_r + Q.other_r + Q.kvp_r).toFixed(1));

Q.center_right_coalition = parseFloat((Q.z_r + Q.fvp_r  + Q.other_r + Q.dnvp_r + Q.kvp_r).toFixed(1));

Q.right_coalition = parseFloat((Q.z_r + Q.nlp_r + Q.other_r + Q.kvp_r + Q.dnvp_r).toFixed(1));

if (Q.dnvp_ideology === "Moderate") {
    Q.far_right_coalition = parseFloat((Q.dnf_r + Q.nsdap_r).toFixed(1));
} else {
    Q.far_right_coalition = parseFloat((Q.dnvp_r + Q.nsdap_r).toFixed(1));
}

Q.left_coalition = parseFloat((Q.spd_r + Q.uspd_r + Q.sapd_r).toFixed(1));

if (Q.lvp_formed) {
    Q.popular_front_coalition = parseFloat((Q.spd_r + Q.uspd_r + Q.z_r - Q.bvp_r + Q.sapd_r).toFixed(1));
} else if (Q.liberal_parliament == 0 && Q.bourgeois_parliament_fvp == 0) {
    Q.popular_front_coalition = parseFloat((Q.spd_r + Q.uspd_r + Q.z_r + Q.fvp_r - Q.bvp_r + Q.sapd_r).toFixed(1));
} else if (Q.liberal_parliament == 1 || Q.bourgeois_parliament_fvp == 1) {
    Q.popular_front_coalition = parseFloat((Q.spd_r + Q.uspd_r + Q.z_r - Q.bvp_r + Q.sapd_r).toFixed(1));
}

if (Q.dnvp_ideology === "Moderate") {
    Q.anti_democratic_coalition = parseFloat((Q.uspd_r + Q.nsdap_r + Q.dnf_r).toFixed(1));
} else {
    Q.anti_democratic_coalition = parseFloat((Q.uspd_r + Q.nsdap_r + Q.dnvp_r).toFixed(1));
}

if (Q.lvp_formed) {
    Q.neo_weimar_coalition = parseFloat((Q.spd_r + Q.lvp_r + Q.z_r + Q.other_r).toFixed(1));
} else {
    Q.neo_weimar_coalition = parseFloat((Q.spd_r + Q.fvp_r + Q.z_r + Q.nlp_r + Q.other_r).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.cordon_sanitaire = parseFloat((Q.spd_r + Q.lvp_r + Q.z_r + Q.other_r + Q.kvp_r).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.cordon_sanitaire = parseFloat((Q.spd_r + Q.fvp_r + Q.z_r + Q.nlp_r + Q.other_r + Q.dnvp_r + Q.kvp_r).toFixed(1));
} else if (Q.lvp_formed && !Q.kvp_formed) {
    Q.cordon_sanitaire = parseFloat((Q.spd_r + Q.z_r + Q.lvp_r + Q.other_r + Q.dnvp_r).toFixed(1));
} else {
    Q.cordon_sanitaire = parseFloat((Q.spd_r + Q.z_r + Q.fvp_r + Q.nlp_r + Q.other_r + Q.dnvp_r).toFixed(1));
}

Q.hitler_right_coalition = parseFloat((Q.z_r + Q.nsdap_r).toFixed(1));

Q.goerdeler_right_coalition = parseFloat((Q.z_r + Q.nlp_r + Q.lvp_r + Q.other_r + Q.kvp_r + Q.dnvp_r + Q.dnf_r).toFixed(1));

if (Q.lvp_formed) {
    Q.progressive_coalition = parseFloat((Q.spd_r + Q.uspd_r + (Q.lvp_r / 3) + Q.sapd_r).toFixed(1));
} else {
    Q.progressive_coalition = parseFloat((Q.spd_r + Q.uspd_r + Q.fvp_r + Q.sapd_r).toFixed(1));
}

if (Q.dnef_formed) {
    Q.schleicher_right_coalition = parseFloat((Q.dnef_r + Q.lvp_r + Q.nlp_r + Q.fvp_r + Q.z_r + Q.other_r + Q.kvp_r + Q.dnvp_r + Q.dnf_r + Q.dsu_r).toFixed(1));
    Q.schleicher_left_coalition = parseFloat((Q.dnef_r + Q.spd_r + Q.lvp_r + Q.nlp_r + Q.fvp_r + Q.z_r).toFixed(1));
}

if (Q.lvp_formed) {
    Q.weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia ).toFixed(1));
} else {
    Q.weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.social_liberal_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia).toFixed(1));
} else {
    Q.social_liberal_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.fvp_r_prussia).toFixed(1));
}

Q.social_catholic_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.grand_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia).toFixed(1));
} else {
    Q.grand_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia + Q.nlp_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.fvp_r_prussia + Q.z_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.lvp_formed && !Q.kvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia).toFixed(1));
} else {
    Q.bourgeois_coalition_prussia = parseFloat((Q.fvp_r_prussia + Q.z_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.fvp_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (!Q.kvp_formed && Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.fvp_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.dnvp_ideology === "Moderate") {
    Q.far_right_coalition_prussia = parseFloat((Q.dnf_r_prussia + Q.nsdap_r_prussia).toFixed(1));
} else {
    Q.far_right_coalition_prussia = parseFloat((Q.dnvp_r_prussia + Q.nsdap_r_prussia).toFixed(1));
}

if (Q.nlp_leader == "Dingeldey" && Q.nlp_ideology == "Right" && Q.nlp_right - Q.nlp_left >= 15 || Q.hugenberg_nlp) {
    Q.far_right_coalition_prussia = parseFloat((Q.far_right_coalition_prussia + Q.nlp_r_prussia).toFixed(1));
}

Q.left_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + Q.sapd_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + Q.z_r_prussia + Q.sapd_r_prussia).toFixed(1));
} else if (Q.liberal_parliament == 0) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + Q.z_r_prussia + Q.fvp_r_prussia + Q.sapd_r_prussia).toFixed(1));
} else if (Q.liberal_parliament == 1) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + Q.z_r_prussia + Q.sapd_r_prussia).toFixed(1));
}

if (Q.dnvp_ideology === "Moderate") {
    Q.anti_democratic_coalition_prussia = parseFloat((Q.uspd_r_prussia + Q.nsdap_r_prussia + Q.dnf_r_prussia).toFixed(1));
} else {
    Q.anti_democratic_coalition_prussia = parseFloat((Q.uspd_r_prussia + Q.nsdap_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.neo_weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia + Q.other_r_prussia).toFixed(1));
} else {
    Q.neo_weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.lvp_formed && !Q.kvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia + Q.fvp_r_prussia + Q.nlp_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia + Q.dnvp_r).toFixed(1));
}

// Q.hitler_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.dnvp_r_prussia + Q.nsdap_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.progressive_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + (Q.lvp_r_prussia / 2) + Q.sapd_r_prussia).toFixed(1));
} else {
    Q.progressive_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.uspd_r_prussia + Q.fvp_r_prussia + Q.sapd_r_prussia).toFixed(1));
}

if (Q.dnef_formed) {
    Q.schleicher_right_coalition_prussia = parseFloat((Q.dnef_r_prussia + Q.lvp_r_prussia + Q.nlp_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia + Q.dnvp_r_prussia + Q.dnf_r_prussia + Q.dsu_r_prussia).toFixed(1));
    Q.schleicher_left_coalition_prussia = parseFloat((Q.dnef_r_prussia + Q.spd_r_prussia + Q.lvp_r_prussia + Q.fvp_r_prussia + Q.z_r_prussia).toFixed(1));
}

if (Q.uspd_relation >= 30 && Q.sapd_formed == 1) {
    Q.weimar_coalition_prussia += Q.sapd_r_prussia;
}
!}
